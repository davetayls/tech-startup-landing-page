# Uniform API Configuration
# Get these from your Uniform project settings

# API Key for accessing Uniform APIs (required for webhook handler)
UNIFORM_API_KEY=your-uniform-api-key

# Project ID (required)
UNIFORM_PROJECT_ID=your-project-uuid

# Webhook secret for signature verification (recommended for production)
# Set this in Uniform's webhook configuration (via Svix)
UNIFORM_WEBHOOK_SECRET=your-webhook-secret
